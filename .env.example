# ============================================================
# OPÇÃO A: Vercel Postgres (Neon) — recomendado para Vercel
# Estas variáveis são injetadas automaticamente quando você
# cria um banco em Storage > Postgres no painel do Vercel.
# ============================================================
POSTGRES_PRISMA_URL="postgres://USER:PASS@HOST:5432/DB?sslmode=require&pgbouncer=true"
POSTGRES_URL_NON_POOLING="postgres://USER:PASS@HOST:5432/DB?sslmode=require"

# ============================================================
# OPÇÃO B: Supabase / qualquer Postgres — para dev local
# ============================================================
# DATABASE_URL="postgres://USER:PASSWORD@HOST:6543/postgres?sslmode=require&pgbouncer=true"
# DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres?sslmode=require"

# ============================================================
# Autenticação admin (obrigatório em todos os ambientes)
# ============================================================
AUTH_SECRET="gere-uma-string-aleatoria-com-pelo-menos-32-caracteres"
ADMIN_EMAIL="admin@exemplo.com"
# Gerar hash com: npx tsx scripts/hash-password.ts "sua-senha"
ADMIN_PASSWORD_HASH="$2b$12$substitua_pelo_hash_bcrypt"

# ============================================================
# Apify — Busca empresas no Google Maps (server-side only)
# Obtenha em: https://console.apify.com/account/integrations
# NUNCA exponha ao client-side nem ao git!
# ============================================================
APIFY_TOKEN="your-apify-token-here"
